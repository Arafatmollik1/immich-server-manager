{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "docker-commands",
  "description": "Allow the app to run specific docker and docker compose commands",
  "windows": ["main"],
  "permissions": [
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "docker",
          "cmd": "docker",
          "args": ["info", "compose", "up", "-d", "down", "pull", "ps"]
        }
      ]
    }
  ]
}
